PORT=3000
NAS_ROOT=./nas-data
SESSION_SECRET=nas_secure_secret_key_987654321

# Database Configuration
# Set USE_MYSQL=true to connect to MySQL. 
# If USE_MYSQL=false, it will fall back to local nas-data/users.json file storage.
USE_MYSQL=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nas_manager

# SMTP Configuration (For Gmail / Password Reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="NAS Server <noreply@nas.local>"
